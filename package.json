{
  "name": "cipher-watchface",
  "author": "Eduardo Chiaro",
  "version": "1.0.0",
  "keywords": [
    "pebble-app"
  ],
  "private": true,
  "scripts": {
    "build": "pebble clean && pebble build",
    "emulator": "npm run build && pebble install --emulator ",
    "phone": "npm run build && pebble install --phone",
    "config": "pebble emu-app-config --emulator",
    "logs": "pebble logs"
  },
  "pebble": {
    "displayName": "Bill Cipher is watching you",
    "uuid": "fbb4d8b2-3036-4408-8f1b-3a1da81f29e0",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "targetPlatforms": [
      "aplite",
      "basalt",
      "chalk",
      "diorite",
      "emery",
      "flint",
      "gabbro"
    ],
    "watchapp": {
      "watchface": true
    },
    "messageKeys": [
      "TIME_COLOR",
      "FLAT_COLOR",
      "FLICK_ANIMATION",
      "WEATHER_TEMPERATURE",
      "WEATHER_CODE",
      "UNITS",
      "LEFT_MODULE[5]",
      "RIGHT_MODULE[5]"
    ],
    "resources": {
      "media": [
        {
          "file": "menu_icon.png",
          "name": "MENU_ICON",
          "type": "png",
          "menuIcon": true
        },
        {
          "type": "bitmap",
          "name": "IMAGE_BACKGROUND",
          "file": "background.png"
        },
        {
          "type": "bitmap",
          "name": "IMAGE_BATTERY",
          "file": "battery.png"
        },
        {
          "type": "bitmap",
          "name": "IMAGE_NUMBERS",
          "file": "numbers.png"
        },
        {
          "type": "bitmap",
          "name": "IMAGE_LETTERS",
          "file": "letters.png"
        },
        {
          "type": "bitmap",
          "name": "IMAGE_ICONS",
          "file": "icons.png"
        }
      ]
    }
  },
  "dependencies": {
    "@rebble/clay": "^1.0.10"
  }
}
